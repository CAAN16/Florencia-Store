# ================================================================
#  FLORENCIA — Variables de Entorno del Backend
#  Copia este archivo como .env y configura tus valores reales.
#  NUNCA subas el archivo .env al repositorio.
# ================================================================

# --- Base de Datos ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=florencia_db
DB_USER=root
DB_PASS=

# --- JWT / Sesión ---
# Clave secreta para firmar tokens o cookies de sesión
SESSION_SECRET=cambia_esta_clave_secreta_por_una_muy_segura

# --- Entorno ---
# Valores: development | production
APP_ENV=development

# --- CORS ---
# URL del frontend Next.js (sin barra al final)
FRONTEND_URL=http://localhost:3000

# --- Subida de archivos ---
# Tamaño máximo de imagen en bytes (2 MB)
MAX_UPLOAD_SIZE=2097152
